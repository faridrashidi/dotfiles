#!/usr/bin/env bash

mkdir -p "$HOME/.local/bin"

npm -g install \
    sharp-cli \
    @openai/codex \
    @anthropic-ai/claude-code
pipx install \
    dooti \
    llmfit

curl -L https://raw.githubusercontent.com/fboender/multi-git-status/master/mgitstatus -o ~/.local/bin/mgitstatus && chmod +x ~/.local/bin/mgitstatus
curl -L https://raw.githubusercontent.com/mklement0/fileicon/master/bin/fileicon -o ~/.local/bin/fileicon && chmod +x ~/.local/bin/fileicon
curl -fsSL https://raw.githubusercontent.com/tw93/mole/main/install.sh | bash -s -- --prefix "$HOME/.local/bin"
OP_VER="$(curl -fsSL https://app-updates.agilebits.com/product_history/CLI2 | grep -oE 'op_darwin_arm64_v[0-9]+(\.[0-9]+)+\.zip' | head -1 | grep -oE '[0-9]+(\.[0-9]+)+')" && curl -fsSL "https://cache.agilebits.com/dist/1P/op2/pkg/v${OP_VER}/op_darwin_arm64_v${OP_VER}.zip" | bsdtar -xf- -C ~/.local/bin op && chmod +x ~/.local/bin/op

sudo cp "${HOME}/Dropbox/Resources/Mac/Settings/Dotfiles/ghostty/sudo" /private/etc/pam.d/
fileicon set "${HOME}/Dropbox" "${HOME}/Dropbox/Resources/Mac/Settings/Dotfiles/finder/dropbox.png"
ln -s "${HOME}/Resources/Mac/Settings/Dotfiles/scripts/apps-private" "${HOME}/Developer/dotfiles/scripts"
mkdir -p "${HOME}/.ssh" && cp -R "${HOME}/Resources/Mac/Settings/Dotfiles/ssh/." "${HOME}/.ssh/"
