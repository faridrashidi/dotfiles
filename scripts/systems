        \"com.apple.finder.ACTN\", \
        NSToolbarSpaceItem, \
        \"com.apple.finder.SRCH\" \
    ); \
    \"TB Display Mode\" = 2; \
    \"TB Icon Size Mode\" = 1; \
    \"TB Is Shown\" = 1; \
    \"TB Item Identifiers\" =     ( \
        \"com.apple.finder.BACK\", \
        \"com.apple.finder.SRCH\" \
    ); \
    \"TB Size Mode\" = 1; \
} \
'"

# Show the hidden ~/Library folder
execute "chflags nohidden \"${HOME}/Library\""

