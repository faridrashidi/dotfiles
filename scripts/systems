###############################################################################
# Manual Configuration Prompts                                                #
###############################################################################

# Function to print colored bullet messages
message() {
    local -r bullet_color="$1" message="$2"
    local -rA colors=([black]=0 [red]=1 [green]=2 [yellow]=3 [blue]=4 [magenta]=5 [cyan]=6 [white]=7)
    if [[ -n "${colors[$bullet_color]+x}" ]]; then
        echo -e "$(tput setaf "${colors[$bullet_color]}")•$(tput sgr0) ${message}"
    else
        echo "${FUNCNAME[0]}: '${bullet_color}' is not a valid color."
        return 1
    fi
}

# Function to prompt user to open an app with arguments
ask_gui() {
    # message 'yellow' "${1}"
    # open -Wa "${2}" --args "${@:3}"
    print_msg "$1" "warning"
}

# Function to prompt user to adjust System Settings
ask_system_settings() {
    # open "${2}"
    ask_gui "$1" 'System Settings'
}

# Run manual configuration steps
if [[ -z "$CI" ]]; then
    ask_system_settings 'Turn off unnecessary apps from iCloud' \
        'x-apple.systempreferences:com.apple.preferences.AppleIDPrefPane?iCloud'
    ask_system_settings 'Turn off all notifs except Message' \
        'x-apple.systempreferences:com.apple.preference.notifications'
    ask_system_settings 'Night Shift... -> Sunset to Sunrise' \
        'x-apple.systempreferences:com.apple.preference.displays'
    ask_system_settings 'Input Sources -> Edit... -> Persian -> keyboard shortcuts -> On keyboard shortcuts' \
        'x-apple.systempreferences:com.apple.preference.keyboard?InputSources'
fi
